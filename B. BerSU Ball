#include<bits/stdc++.h>
using namespace std;
using ll=long long;
const int maxN=101;
vector<pair<int,int>> adj[maxN][maxN];
bool visited[maxN][maxN];
int ans=0;
void dfs(int val,int i)
{
    for(auto child:adj[val][i])
    {
        if(!visited[child.first][child.second])
        {
            visited[child.first][child.second]=true;
            ans++;
            return;
        }
    }
}
void solve()
{
    int n,m;
    cin >> n;
    int a[n+1];
    for(int i=1; i<=n; i++)
        cin >> a[i];
    cin >> m;
    int b[m+1];
    for(int j=1; j<=m; j++)
        cin >> b[j];
    sort(a+1,a+n+1);
    sort(b+1,b+m+1);
    for(int i=1; i<=n; i++)
        for(int j=1; j<=m; j++)
            if(abs(a[i]-b[j])<=1)
                adj[a[i]][i].push_back({b[j],j});
    for(int i=1; i<=n; i++)
        dfs(a[i],i);
    cout << ans << '\n';
}
int main()
{
    ios_base::sync_with_stdio(0);
    cin.tie(0);
    cout.tie(0);
    int t=1;
    //cin >> t;
    while(t--)
        solve();
    return 0;
}
