#include <bits/stdc++.h>
using namespace std;
 
int main()
{
    int t;
    cin>>t;
    while(t--)
    {
        int n;
        cin>>n;
        int even_s=0;
        int odd_s=0;
 
        for(int i=0; i<n; i++)
        {
            int x;
            cin>>x;
            if(x%2==0)
            {
                even_s+=x;
            }
            else
            {
                odd_s+=x;
            }
        }
 
        if(even_s>odd_s)
        {
            cout<<"YES"<<endl;
        }
        else
        {
            cout<<"NO"<<endl;
        }
    }
 
    return 0;
}
