#include <bits/stdc++.h>
using namespace std;
#define int long long
void answer() {
    int a,b,c; cin >> a >> b >> c;
    if((c + a) % (2 * b) == 0) cout << "YES" << '\n';
    else if((2 * b - c) > 0 and (2 * b - c) % a == 0) cout << "YES" << '\n';
    else if((2 * b - a) > 0 and (2 * b - a) % c == 0) cout << "YES" << '\n';
    else cout << "NO" << '\n';
}
 
int32_t main() {
    ios_base::sync_with_stdio(0);
    cin.tie(0);
    cout.tie(0);
    int tc = 1;
    cin >> tc;
    while (tc--) {
        answer();
    }
 
    return 0;
}
