#include<bits/stdc++.h>
using namespace std;

int main()
{
    int t;
    cin >> t;

    while (t--)
    {
        int n;
        cin >> n;

        vector<int> arr(n);
        for(int i = 0; i < n; i++)
        {
            cin >> arr[i];
        }

        int total2 = count(arr.begin(), arr.end(), 2);

        if(total2 % 2 != 0)
        {
            cout << -1 << endl;
            continue;
        }

        if(total2 == 0)
        {
            cout << 1 << endl;
            continue;
        }

        int left = 0;
        for(int i = 0; i < n-1; i++)
        {
            if(arr[i] == 2) left++;

            if(left == total2/2)
            {
                cout << i + 1 << endl;
                break;
            }
        }
    }

    return 0;
}
