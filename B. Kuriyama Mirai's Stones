#include<bits/stdc++.h>
#define ll long long
#define MOD 1000000007
 
using namespace std;
 
ll u[1000000],v[1000000];
 
int main()
{
	int n,m,i,j,typ,l,r;
	ll cnt1=0,cnt2=0;
	cin>>n;
	v[0]=0;
	u[0]=0;
	for(i=1;i<=n;i++){
		cin>>v[i];
		u[i]=v[i];
	}
	sort(u,u+n+1);
	for(i=2;i<=n;i++){
		v[i]=v[i]+v[i-1];
		u[i]=u[i]+u[i-1];
	}
	cin>>m;
	for(i=0;i<m;i++){
		cin>>typ>>l>>r;
		if(typ==1) cout<<v[r]-v[l-1]<<endl;
		else cout<<u[r]-u[l-1]<<endl;
	}
	return 0;
}
